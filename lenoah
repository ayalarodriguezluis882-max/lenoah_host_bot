- T-MEC (origen EE.UU. con cert): usa tlc_igi (generalmente 0% para la mayoría de bienes industriales)
- Sin T-MEC o no origen EE.UU.: usa igi general TIGIE
- IEPS solo si aplica (bebidas alcohólicas, tabaco, combustibles, refrescos, alimentos con alto contenido calórico)

REGLAS DE CONFIANZA:
- ALTA: producto muy específico, descripción completa, fracción inequívoca
- MEDIA: producto con posibles fracciones alternativas, descripción parcial
- BAJA: producto ambiguo, descripción insuficiente, requiere análisis técnico profesional

SIEMPRE añade disclaimer: "Esta clasificación es preliminar y orientativa. Un agente aduanal certificado debe validar la fracción arancelaria final."

Sé conciso, profesional y didáctico. Explica brevemente por qué elegiste esa fracción.`;

// ── RENDER HELPERS ─────────────────────────────────────
function qzPanel() { return document.getElementById('qz-panel'); }

function qzAddBubble(role, html, tag) {
  const panel = qzPanel();
  const wrap = document.createElement('div');
  wrap.style.cssText = `display:flex;flex-direction:column;gap:3px;margin-bottom:12px;animation:mIn .4s both;${role==='nova'?'align-items:flex-start':'align-items:flex-end'}`;
  const who = document.createElement('div');
  who.style.cssText = 'font-size:8px;letter-spacing:.28em;text-transform:uppercase;color:var(--text-3);font-family:var(--font-b);';
  who.textContent = role === 'nova' ? 'NOVA · Clasificador' : 'Cliente';
  const bubble = document.createElement('div');
  bubble.style.cssText = role === 'nova'
    ? 'max-width:95%;padding:10px 13px;background:var(--jade-dim);border:1px solid var(--border);border-left:2px solid var(--jade);font-size:12px;line-height:1.65;color:var(--text);border-radius:0 4px 4px 4px;'
    : 'max-width:88%;padding:9px 13px;background:rgba(255,255,255,.03);border:1px solid rgba(255,255,255,.06);font-size:12px;line-height:1.65;color:var(--text-2);border-radius:4px 0 4px 4px;';
  bubble.innerHTML = html;
  if(tag) wrap.setAttribute('data-tag', tag);
  wrap.appendChild(who); wrap.appendChild(bubble);
  panel.appendChild(wrap);
  panel.scrollTop = panel.scrollHeight;
  return bubble;
}

function qzAddThinking() {
  const panel = qzPanel();
  const wrap = document.createElement('div');
  wrap.id = 'qzThink';
  wrap.style.cssText = 'display:flex;flex-direction:column;gap:3px;margin-bottom:12px;align-items:flex-start;';
  wrap.innerHTML = '<div style="font-size:8px;letter-spacing:.28em;text-transform:uppercase;color:var(--text-3);">NOVA · Clasificador</div><div class="thinking"><div class="td"></div><div class="td"></div><div class="td"></div></div>';
  panel.appendChild(wrap); panel.scrollTop = panel.scrollHeight;
}
function qzHideThinking() { document.getElementById('qzThink')?.remove(); }

function qzAddDivider(text) {
  const panel = qzPanel();
  const d = document.createElement('div');
  d.style.cssText = 'display:flex;align-items:center;gap:10px;margin:10px 0;';
  d.innerHTML = `<div style="flex:1;height:1px;background:var(--border);"></div><div style="font-size:8px;letter-spacing:.3em;text-transform:uppercase;color:var(--text-3);">${text}</div><div style="flex:1;height:1px;background:var(--border);"></div>`;
  panel.appendChild(d);
}

// ── RESULT CARD ────────────────────────────────────────
function qzRenderResult(data) {
  const { fraction, desc, invoiceUSD, freightUSD, insuranceUSD, igiPct, iepsPct, tlc, origin, product, restrictions, noms, confidence, alternatives, fractionFull } = data;

  // CÁLCULOS
  const valAduana = (invoiceUSD + freightUSD + insuranceUSD) * 20.5; // USD→MXN aprox
  const igiBase   = tlc ? 0 : igiPct / 100;
  const igi       = valAduana * igiBase;
  const baseIVA   = valAduana + igi;
  const iva       = baseIVA * 0.16;
  const dta       = valAduana * 0.008;   // 8 al millar
  const ieps      = iepsPct > 0 ? valAduana * (iepsPct / 100) : 0;
  const subtotalImpuestos = igi + iva + dta + ieps;
  const honorarios = subtotalImpuestos * 0.30;
  const totalFinal = subtotalImpuestos + honorarios;

  const fmt = (n) => '$' + n.toLocaleString('es-MX', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
  const confColor = confidence === 'ALTA' ? '#3ecf8e' : confidence === 'MEDIA' ? '#f0b429' : '#f87171';
  const confIcon  = confidence === 'ALTA' ? '✓' : confidence === 'MEDIA' ? '⚠' : '⚡';

  const html = `
  <div style="font-size:8px;letter-spacing:.35em;text-transform:uppercase;color:var(--text-2);margin-bottom:10px;">Cotización preliminar · ${new Date().toLocaleDateString('es-MX')}</div>

  <!-- FRACCIÓN -->
  <div style="border:1px solid var(--border2);padding:12px;margin-bottom:8px;background:rgba(5,7,10,.5);">
    <div style="display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:6px;">
      <div>
        <div style="font-family:var(--font-m);font-size:22px;color:var(--jade);letter-spacing:.08em;">${fractionFull}</div>
        <div style="font-size:11px;color:var(--text);margin-top:3px;">${desc}</div>
      </div>
      <div style="text-align:right;flex-shrink:0;margin-left:10px;">
        <div style="font-size:9px;letter-spacing:.2em;text-transform:uppercase;color:${confColor};border:1px solid ${confColor};padding:3px 8px;">${confIcon} ${confidence}</div>
      </div>
    </div>
    <div style="font-size:10px;color:var(--text-2);">Producto: <span style="color:var(--text);">${product}</span></div>
    <div style="font-size:10px;color:var(--text-2);margin-top:2px;">Origen: <span style="color:var(--text);">${origin}</span> ${tlc ? '<span style="color:var(--jade);margin-left:6px;">✓ T-MEC aplicable</span>' : ''}</div>
    ${alternatives && alternatives.length ? `<div style="font-size:10px;color:var(--text-3);margin-top:4px;">Fracciones alternativas: ${alternatives.join(', ')}</div>` : ''}
  </div>

  <!-- BASE DE CÁLCULO -->
  <div style="border:1px solid var(--border);padding:10px;margin-bottom:8px;">
    <div style="font-size:8px;letter-spacing:.3em;text-transform:uppercase;color:var(--text-2);margin-bottom:8px;">Base de cálculo</div>
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:4px;font-size:11px;">
      <div style="color:var(--text-2);">Valor factura</div><div style="text-align:right;font-family:var(--font-m);color:var(--text);">$${invoiceUSD.toLocaleString()} USD</div>
      <div style="color:var(--text-2);">Flete intl.</div><div style="text-align:right;font-family:var(--font-m);color:var(--text);">$${freightUSD.toLocaleString()} USD</div>
      <div style="color:var(--text-2);">Seguro</div><div style="text-align:right;font-family:var(--font-m);color:var(--text);">$${insuranceUSD.toFixed(0)} USD</div>
      <div style="color:var(--text-2);border-top:1px solid var(--border);padding-top:4px;margin-top:2px;">Valor en aduana (~20.5)</div>
      <div style="text-align:right;font-family:var(--font-m);color:var(--jade);border-top:1px solid var(--border);padding-top:4px;margin-top:2px;">${fmt(valAduana)}</div>
    </div>
  </div>

  <!-- IMPUESTOS -->
  <div style="border:1px solid var(--border);padding:10px;margin-bottom:8px;">
    <div style="font-size:8px;letter-spacing:.3em;text-transform:uppercase;color:var(--text-2);margin-bottom:8px;">Impuestos estimados</div>
    <div style="display:grid;grid-template-columns:1fr auto auto;gap:4px;font-size:11px;align-items:center;">
      <div style="color:var(--text-2);">IGI ${tlc?'(T-MEC 0%)':'('+igiPct+'%)'}</div>
      <div style="color:var(--text-3);font-size:10px;text-align:right;">${fmt(igi)}</div>
      <div style="width:40px;"></div>
      <div style="color:var(--text-2);">IVA (16%)</div>
      <div style="color:var(--text-3);font-size:10px;text-align:right;">${fmt(iva)}</div>
      <div style="width:40px;"></div>
      <div style="color:var(--text-2);">DTA (8‰)</div>
      <div style="color:var(--text-3);font-size:10px;text-align:right;">${fmt(dta)}</div>
      <div style="width:40px;"></div>
      ${ieps > 0 ? `<div style="color:var(--text-2);">IEPS (${iepsPct}%)</div><div style="color:var(--text-3);font-size:10px;text-align:right;">${fmt(ieps)}</div><div style="width:40px;"></div>` : ''}
      <div style="color:var(--text);border-top:1px solid var(--border);padding-top:4px;margin-top:2px;font-weight:500;">Subtotal impuestos</div>
      <div style="color:var(--text);font-family:var(--font-m);border-top:1px solid var(--border);padding-top:4px;margin-top:2px;">${fmt(subtotalImpuestos)}</div>
      <div style="width:40px;border-top:1px solid var(--border);padding-top:4px;margin-top:2px;"></div>
