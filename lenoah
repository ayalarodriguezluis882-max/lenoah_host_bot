<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no">
<title>LenoahHost · Nova Prestige</title>
<link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=Outfit:wght@200;300;400;500&family=DM+Mono:wght@300;400&display=swap" rel="stylesheet">
<style>
:root{
  --bg:#05070a;--deep:#080c12;--surface:#0d1420;--card:#111926;
  --jade:#3ecf8e;--jade2:#2ab377;--jade-dim:rgba(62,207,142,.10);--jade-glow:rgba(62,207,142,.28);
  --amber:#f0b429;--rose:#f87171;--text:#e2ddd6;--text-2:#8b8680;--text-3:#3d3c3a;
  --border:rgba(62,207,142,.14);--border2:rgba(62,207,142,.28);
  --font-d:'DM Serif Display',serif;--font-b:'Outfit',sans-serif;--font-m:'DM Mono',monospace;
}
*,*::before,*::after{margin:0;padding:0;box-sizing:border-box;}
html,body{width:100%;height:100%;overflow:hidden;background:var(--bg);color:var(--text);font-family:var(--font-b);font-weight:300;}
body{cursor:none;}
#cur{position:fixed;width:7px;height:7px;background:var(--jade);border-radius:50%;pointer-events:none;z-index:9999;transform:translate(-50%,-50%);box-shadow:0 0 12px var(--jade);}
#cur2{position:fixed;width:32px;height:32px;border:1px solid rgba(62,207,142,.35);border-radius:50%;pointer-events:none;z-index:9998;transform:translate(-50%,-50%);transition:width .3s,height .3s;}
#bgC{position:fixed;inset:0;z-index:0;}
.grain{position:fixed;inset:0;z-index:1;pointer-events:none;opacity:.03;background-image:url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='.85' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");}

/* IDLE */
#idle{position:fixed;inset:0;z-index:80;display:flex;flex-direction:column;align-items:center;justify-content:center;transition:opacity .9s,visibility .9s;}
#idle.gone{opacity:0;visibility:hidden;pointer-events:none;}
.idle-wordmark{font-family:var(--font-d);font-size:clamp(52px,9vw,90px);letter-spacing:.12em;color:var(--text);text-transform:uppercase;line-height:1;margin-bottom:4px;}
.idle-wordmark b{color:var(--jade);font-weight:400;}
.idle-rule{width:0;height:1px;background:linear-gradient(90deg,transparent,var(--jade),transparent);animation:rExp 2s .5s ease forwards;}
@keyframes rExp{to{width:200px;}}
.idle-sub{margin-top:14px;font-size:10px;letter-spacing:.55em;text-transform:uppercase;color:var(--text-2);margin-bottom:44px;}
.idle-strip{display:flex;align-items:center;gap:28px;padding:14px 28px;border:1px solid var(--border);background:rgba(13,20,32,.6);backdrop-filter:blur(12px);margin-bottom:44px;}
.si{display:flex;flex-direction:column;align-items:center;gap:3px;}
.sv{font-family:var(--font-d);font-size:26px;color:var(--text);}
.sl{font-size:9px;letter-spacing:.35em;text-transform:uppercase;color:var(--text-2);}
.sdiv{width:1px;height:34px;background:var(--border);}
.idle-quote{font-family:var(--font-d);font-style:italic;font-size:clamp(15px,2.2vw,20px);color:rgba(226,221,214,.38);text-align:center;max-width:480px;line-height:1.75;min-height:64px;display:flex;align-items:center;justify-content:center;padding:0 24px;transition:opacity .55s;margin-bottom:44px;}
.idle-sensor{display:flex;align-items:center;gap:14px;}
.sorb{width:44px;height:44px;border-radius:50%;border:1px solid var(--border2);display:flex;align-items:center;justify-content:center;position:relative;}
.sorb::before{content:'';position:absolute;inset:-7px;border-radius:50%;border:1px solid rgba(62,207,142,.15);animation:sonar 2.4s ease-in-out infinite;}
.sorb::after{content:'';position:absolute;inset:-15px;border-radius:50%;border:1px solid rgba(62,207,142,.07);animation:sonar 2.4s ease-in-out infinite .5s;}
@keyframes sonar{0%,100%{transform:scale(1);opacity:.8}50%{transform:scale(1.08);opacity:.3}}
.sico{width:18px;height:18px;stroke:var(--jade);fill:none;stroke-width:1.5;stroke-linecap:round;}
.stxt{font-size:10px;letter-spacing:.28em;text-transform:uppercase;color:var(--text-2);}

/* WAKE */
#wkL{position:fixed;inset:0;z-index:75;pointer-events:none;opacity:0;transition:opacity .3s;}
#wkL.on{opacity:1;}
#wkC{width:100%;height:100%;}

/* APP */
#app{position:fixed;inset:0;z-index:60;display:grid;grid-template-rows:56px 1fr 44px;opacity:0;visibility:hidden;transition:opacity .7s .4s,visibility .7s .4s;}
#app.on{opacity:1;visibility:visible;}

/* HEADER */
.hdr{display:flex;align-items:center;justify-content:space-between;padding:0 28px;border-bottom:1px solid var(--border);background:rgba(5,7,10,.7);backdrop-filter:blur(20px);}
.hdr-brand{display:flex;align-items:baseline;gap:12px;}
.hdr-name{font-family:var(--font-d);font-size:19px;letter-spacing:.18em;text-transform:uppercase;}
.hdr-name span{color:var(--jade);}
.hdr-dot{width:1px;height:13px;background:var(--border2);}
.hdr-sub{font-size:9px;letter-spacing:.38em;text-transform:uppercase;color:var(--text-2);}
.hdr-r{display:flex;align-items:center;gap:18px;}
.hdr-wx{display:flex;align-items:center;gap:6px;font-size:12px;color:var(--text-2);}
.hdr-clock{font-family:var(--font-m);font-size:19px;color:var(--text-2);letter-spacing:.06em;}
.tabs{display:flex;gap:2px;}
.tab{padding:6px 13px;border:none;background:transparent;font-family:var(--font-b);font-size:9px;letter-spacing:.28em;text-transform:uppercase;color:var(--text-2);cursor:none;border-bottom:2px solid transparent;transition:all .25s;}
.tab.on{color:var(--jade);border-bottom-color:var(--jade);}.tab.on#tabQuote{color:var(--amber);border-bottom-color:var(--amber);}
.tab:hover{color:var(--text);}

/* STAGE */
.stage{display:grid;grid-template-columns:1fr 375px;overflow:hidden;}

/* AVATAR */
.avp{display:flex;flex-direction:column;align-items:center;justify-content:center;position:relative;padding:20px;overflow:hidden;}
.apbg{position:absolute;inset:0;background:radial-gradient(ellipse at 50% 40%,rgba(62,207,142,.04) 0%,transparent 65%);pointer-events:none;}
.cm{position:absolute;width:20px;height:20px;opacity:.32;}
.cm-tl{top:16px;left:16px;border-top:1px solid var(--jade);border-left:1px solid var(--jade);}
.cm-tr{top:16px;right:16px;border-top:1px solid var(--jade);border-right:1px solid var(--jade);}
.cm-bl{bottom:16px;left:16px;border-bottom:1px solid var(--jade);border-left:1px solid var(--jade);}
.cm-br{bottom:16px;right:16px;border-bottom:1px solid var(--jade);border-right:1px solid var(--jade);}
.ow{position:relative;width:195px;height:195px;margin-bottom:18px;}
.oa{position:absolute;inset:-26px;border-radius:50%;background:radial-gradient(circle,rgba(62,207,142,.07) 0%,transparent 70%);animation:aura 4s ease-in-out infinite;}
@keyframes aura{0%,100%{transform:scale(1);opacity:.5}50%{transform:scale(1.12);opacity:1}}
.or1{position:absolute;inset:0;border-radius:50%;border:1px solid rgba(62,207,142,.2);animation:sp1 22s linear infinite;}
.or1::before{content:'';position:absolute;width:8px;height:8px;background:var(--jade);border-radius:50%;top:-4px;left:50%;transform:translateX(-50%);box-shadow:0 0 16px var(--jade),0 0 32px var(--jade-glow);}
@keyframes sp1{to{transform:rotate(360deg);}}
.or2{position:absolute;inset:14px;border-radius:50%;border:1px solid rgba(62,207,142,.09);animation:sp1 16s linear infinite reverse;}
.or2::after{content:'';position:absolute;width:5px;height:5px;background:var(--jade);border-radius:50%;bottom:-2.5px;right:22%;opacity:.5;}
.of{position:absolute;inset:26px;border-radius:50%;background:radial-gradient(circle at 37% 30%,#1b2535 0%,#0a0e18 55%,#05070a 100%);border:1px solid var(--border2);display:flex;align-items:center;justify-content:center;overflow:hidden;}
.of::before{content:'';position:absolute;width:55%;height:38%;top:8%;left:22%;background:radial-gradient(ellipse,rgba(62,207,142,.06) 0%,transparent 80%);border-radius:50%;}
#faceC{width:90px;height:90px;position:relative;z-index:1;}
.avst{text-align:center;margin-bottom:12px;}
.avlbl{font-size:8px;letter-spacing:.45em;text-transform:uppercase;color:var(--text-3);margin-bottom:4px;}
.avval{font-family:var(--font-d);font-size:22px;color:var(--text);transition:color .4s;}
.avval.sp{color:var(--jade);}
.wave{display:flex;align-items:center;gap:2px;height:28px;margin-bottom:12px;}
.wb{width:2px;border-radius:2px;background:var(--jade);height:5px;opacity:.18;transition:height .08s,opacity .08s;}
.wb.on{opacity:.8;}
.vc{display:flex;align-items:center;gap:8px;padding:5px 12px;border:1px solid var(--border);background:var(--jade-dim);font-size:9px;letter-spacing:.2em;text-transform:uppercase;opacity:0;transform:translateY(5px);transition:opacity .4s,transform .4s;}
.vc.show{opacity:1;transform:none;}
.vcl{color:var(--text-3);}.vcn{color:var(--jade);font-weight:500;}
.qs-row{display:flex;gap:8px;margin-top:16px;}
.qs{flex:1;padding:8px 8px;border:1px solid var(--border);background:rgba(13,20,32,.5);text-align:center;}
.qsv{font-family:var(--font-m);font-size:17px;color:var(--jade);}
.qsl{font-size:7px;letter-spacing:.2em;text-transform:uppercase;color:var(--text-2);margin-top:2px;}

/* RIGHT */
.rp{border-left:1px solid var(--border);display:flex;flex-direction:column;background:rgba(8,12,18,.75);backdrop-filter:blur(18px);}
.tc{display:none;flex:1;overflow:hidden;flex-direction:column;}
.tc.on{display:flex;}

/* CHAT */
.msgs{flex:1;overflow-y:auto;padding:16px;display:flex;flex-direction:column;gap:14px;scrollbar-width:thin;scrollbar-color:var(--border) transparent;}
.msgs::-webkit-scrollbar{width:3px;}.msgs::-webkit-scrollbar-thumb{background:var(--border);}
.msg{display:flex;flex-direction:column;gap:4px;animation:mIn .4s cubic-bezier(.22,1,.36,1) both;}
@keyframes mIn{from{opacity:0;transform:translateY(8px)}to{opacity:1;transform:none}}
.msg.nova{align-items:flex-start;}.msg.vis{align-items:flex-end;}
.mwho{font-size:8px;letter-spacing:.28em;text-transform:uppercase;color:var(--text-3);}
.mbody{max-width:90%;padding:10px 14px;font-size:12.5px;line-height:1.7;font-weight:300;}
.msg.nova .mbody{background:var(--jade-dim);border:1px solid var(--border);border-left:2px solid var(--jade);border-radius:0 4px 4px 4px;color:var(--text);}
.msg.vis .mbody{background:rgba(255,255,255,.03);border:1px solid rgba(255,255,255,.06);border-radius:4px 0 4px 4px;color:var(--text-2);}
.thinking{display:flex;gap:5px;align-items:center;padding:10px 14px;background:var(--jade-dim);border:1px solid var(--border);border-left:2px solid var(--jade);}
.td{width:4px;height:4px;border-radius:50%;background:var(--jade);animation:td 1.1s ease-in-out infinite;}
.td:nth-child(2){animation-delay:.18s}.td:nth-child(3){animation-delay:.36s}
@keyframes td{0%,100%{opacity:.2;transform:translateY(0)}50%{opacity:1;transform:translateY(-5px)}}
.ctrls{padding:13px 15px;border-top:1px solid var(--border);}
.mic-row{display:flex;align-items:center;gap:11px;margin-bottom:9px;}
.micbtn{width:44px;height:44px;border-radius:50%;border:1px solid var(--border2);background:transparent;cursor:none;display:flex;align-items:center;justify-content:center;transition:all .3s;flex-shrink:0;position:relative;}
.micbtn:hover{background:var(--jade-dim);border-color:var(--jade);}
.micbtn.hot{background:var(--jade-dim);border-color:var(--jade);box-shadow:0 0 20px var(--jade-dim);}
.micbtn.hot::before{content:'';position:absolute;inset:-7px;border-radius:50%;border:1px solid rgba(62,207,142,.3);animation:mr 1.5s ease-in-out infinite;}
@keyframes mr{0%,100%{transform:scale(1);opacity:1}50%{transform:scale(1.06);opacity:.4}}
.mico{width:16px;height:16px;stroke:var(--jade);fill:none;stroke-width:1.5;stroke-linecap:round;stroke-linejoin:round;}
.trw{flex:1;overflow:hidden;}
.trh{font-size:8px;letter-spacing:.25em;text-transform:uppercase;color:var(--text-3);margin-bottom:3px;}
.trt{font-size:12px;color:var(--text-2);font-style:italic;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;min-height:16px;}
.brow{display:grid;grid-template-columns:1fr 1fr 1fr;gap:6px;}
.cbtn{padding:8px 4px;border:1px solid var(--border);background:transparent;color:var(--text-2);font-family:var(--font-b);font-size:8px;letter-spacing:.2em;text-transform:uppercase;cursor:none;transition:all .22s;border-radius:1px;}
.cbtn:hover{border-color:var(--jade);color:var(--jade);background:var(--jade-dim);}

/* VISITS */
.vp{flex:1;overflow-y:auto;padding:15px;}
.vp::-webkit-scrollbar{width:3px;}.vp::-webkit-scrollbar-thumb{background:var(--border);}
.vhdr{display:flex;justify-content:space-between;align-items:center;margin-bottom:12px;padding-bottom:9px;border-bottom:1px solid var(--border);}
.vtit{font-size:9px;letter-spacing:.35em;text-transform:uppercase;color:var(--text-2);}
.vcnt{font-family:var(--font-m);font-size:11px;color:var(--jade);}
.vrow{display:grid;grid-template-columns:auto 1fr auto;gap:9px;align-items:center;padding:9px 11px;border:1px solid var(--border);margin-bottom:5px;background:rgba(13,20,32,.4);animation:mIn .4s both;}
.vrt{font-family:var(--font-m);font-size:10px;color:var(--text-2);}
.vri{overflow:hidden;}
.vrn{font-size:12px;color:var(--text);font-weight:400;margin-bottom:2px;}
.vrr{font-size:10px;color:var(--text-2);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;}
.vrb{padding:3px 7px;border:1px solid var(--border);font-size:8px;letter-spacing:.15em;text-transform:uppercase;color:var(--jade);}
.nv{text-align:center;padding:36px 16px;font-family:var(--font-d);font-style:italic;font-size:15px;color:var(--text-3);}
.expbtn{width:100%;padding:9px;margin-top:9px;border:1px solid var(--border);background:transparent;color:var(--text-2);font-family:var(--font-b);font-size:9px;letter-spacing:.28em;text-transform:uppercase;cursor:none;transition:all .25s;}
.expbtn:hover{border-color:var(--jade);color:var(--jade);background:var(--jade-dim);}

/* DASHBOARD */
.dp{flex:1;overflow-y:auto;padding:15px;display:flex;flex-direction:column;gap:10px;}
.dp::-webkit-scrollbar{width:3px;}.dp::-webkit-scrollbar-thumb{background:var(--border);}
.dkpis{display:grid;grid-template-columns:1fr 1fr;gap:7px;}
.kpi{padding:12px;border:1px solid var(--border);background:rgba(13,20,32,.5);}
.kpiv{font-family:var(--font-m);font-size:24px;color:var(--jade);line-height:1;}
.kpil{font-size:8px;letter-spacing:.28em;text-transform:uppercase;color:var(--text-2);margin-top:4px;}
.kpis{font-size:10px;color:var(--text-3);margin-top:2px;}
.dst{font-size:8px;letter-spacing:.35em;text-transform:uppercase;color:var(--text-2);margin-bottom:7px;}
.hchart{display:flex;align-items:flex-end;gap:3px;height:55px;padding:0 2px;}
.hb{flex:1;background:var(--jade-dim);border:1px solid var(--border);border-bottom:none;transition:height .6s;min-height:4px;cursor:none;}
.hb:hover{background:rgba(62,207,142,.25);}
.hlbls{display:flex;gap:3px;padding:0 2px;margin-top:16px;}
.hl{flex:1;text-align:center;font-size:7px;color:var(--text-3);}
.rrl{display:flex;flex-direction:column;gap:5px;}
.rrow{display:flex;align-items:center;gap:9px;}
.rbw{flex:1;height:3px;background:var(--surface);border-radius:2px;overflow:hidden;}
.rb{height:100%;background:var(--jade);border-radius:2px;transition:width .8s;}
.rln{font-size:9px;color:var(--text-2);width:85px;text-align:right;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;}
.rpc{font-family:var(--font-m);font-size:9px;color:var(--jade);width:30px;text-align:right;}

/* FOOTER */
.ftr{display:flex;align-items:center;justify-content:space-between;padding:0 28px;border-top:1px solid var(--border);background:rgba(5,7,10,.8);backdrop-filter:blur(20px);}
.fi{font-size:8px;letter-spacing:.28em;text-transform:uppercase;color:var(--text-3);display:flex;align-items:center;gap:7px;}
.fp{width:4px;height:4px;border-radius:50%;background:var(--jade);opacity:.6;}
.fpw{background:var(--amber);}

/* CAM */
#camBox{position:fixed;bottom:54px;left:12px;width:68px;height:52px;border:1px solid var(--border);overflow:hidden;opacity:.33;z-index:200;display:none;}
#camVid{width:100%;height:100%;object-fit:cover;}
.clbl{position:absolute;bottom:1px;left:0;right:0;text-align:center;font-size:6px;letter-spacing:.18em;color:var(--jade);background:rgba(0,0,0,.6);padding:1px;}

/* TOAST */
.toast{position:fixed;top:66px;left:50%;transform:translateX(-50%) translateY(-12px);background:var(--jade-dim);border:1px solid var(--border2);color:var(--jade);font-size:10px;letter-spacing:.2em;padding:8px 18px;z-index:400;opacity:0;transition:all .35s;pointer-events:none;text-transform:uppercase;font-family:var(--font-b);}
.toast.show{opacity:1;transform:translateX(-50%) translateY(0);}
</style>
</head>
<body>
<div id="cur"></div><div id="cur2"></div>
<div class="grain"></div>
<canvas id="bgC"></canvas>
<div id="wkL"><canvas id="wkC"></canvas></div>
<div class="toast" id="toast"></div>

<!-- IDLE -->
<div id="idle">
  <div class="idle-wordmark">L<b>e</b>noah</div>
  <div class="idle-rule"></div>
  <div class="idle-sub">Comercializadora · Asistente de Recepción Inteligente</div>
  <div class="idle-strip">
    <div class="si"><div class="sv" id="iClock">--:--</div><div class="sl">Hora</div></div>
    <div class="sdiv"></div>
    <div class="si"><div class="sv" id="iTemp">--°</div><div class="sl">Tijuana</div></div>
    <div class="sdiv"></div>
    <div class="si"><div class="sv" id="iVis">0</div><div class="sl">Visitas hoy</div></div>
    <div class="sdiv"></div>
    <div class="si"><div class="sv" id="iDay">—</div><div class="sl">Día</div></div>
  </div>
  <div class="idle-quote" id="iQuote">"Bienvenido. Cada visita es una oportunidad."</div>
  <div class="idle-sensor">
    <div class="sorb">
      <svg class="sico" viewBox="0 0 24 24"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
    </div>
    <div class="stxt" id="sTxt">Sistema activo · Detectando presencia</div>
  </div>
</div>

<!-- APP -->
<div id="app">
  <header class="hdr">
    <div class="hdr-brand">
      <div class="hdr-name">L<span>e</span>noah</div>
      <div class="hdr-dot"></div>
      <div class="hdr-sub">Nova · IA Recepción</div>
    </div>
    <div class="hdr-r">
      <div class="hdr-wx"><span id="wxIco">🌤</span><span id="wxT">--°C</span></div>
      <div class="tabs">
        <button class="tab on" onclick="swTab('chat',this)">Conversación</button>
        <button class="tab" onclick="swTab('visits',this)">Visitas</button>
        <button class="tab" onclick="swTab('dash',this)">Dashboard</button>
        <button class="tab" id="tabVeh" onclick="swTab('vehicle',this)" style="color:#60a5fa">🚗 Vehículos</button>
        <button class="tab" id="tabQuote" onclick="swTab('quote',this)" style="color:var(--amber)">⬡ Cotización</button>
      </div>
      <div class="hdr-clock" id="hClock">00:00</div>
    </div>
  </header>

  <div class="stage">
    <!-- AVATAR -->
    <div class="avp">
      <div class="apbg"></div>
      <div class="cm cm-tl"></div><div class="cm cm-tr"></div>
      <div class="cm cm-bl"></div><div class="cm cm-br"></div>
      <div class="ow">
        <div class="oa"></div><div class="or1"></div><div class="or2"></div>
        <div class="of"><canvas id="faceC" width="90" height="90"></canvas></div>
      </div>
      <div class="wave" id="waveEl">
        <div class="wb"></div><div class="wb"></div><div class="wb"></div><div class="wb"></div>
        <div class="wb"></div><div class="wb"></div><div class="wb"></div><div class="wb"></div>
        <div class="wb"></div><div class="wb"></div><div class="wb"></div><div class="wb"></div>
        <div class="wb"></div><div class="wb"></div><div class="wb"></div>
      </div>
      <div class="avst">
        <div class="avlbl" id="stLbl">Estado</div>
        <div class="avval" id="stVal">En espera</div>
      </div>
      <div class="vc" id="vcChip"><span class="vcl">Visitante</span><span class="vcn" id="vcName">—</span></div>
      <div class="qs-row">
        <div class="qs"><div class="qsv" id="qsV">0</div><div class="qsl">Visitas hoy</div></div>
        <div class="qs"><div class="qsv" id="qsT" style="font-size:12px;padding-top:2px">--:--</div><div class="qsl">Última</div></div>
        <div class="qs"><div class="qsv" id="qsA">0m</div><div class="qsl">Prom. espera</div></div>
