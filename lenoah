<script>
// ══ API KEY MANAGEMENT ══
function getKey(){return localStorage.getItem('lh_apikey')||'';}
function saveKey(){
  const val=document.getElementById('keyInput').value.trim();
  if(!val||!val.startsWith('AIza')){
    document.getElementById('keyMsg').textContent='Key inválida. Debe comenzar con "AIza..."';return;}
  localStorage.setItem('lh_apikey',val);
  document.getElementById('setupScreen').style.display='none';
  document.getElementById('keyMsg').textContent='';
  initApp();
}
function toggleKeyVis(){const i=document.getElementById('keyInput');i.type=i.type==='password'?'text':'password';}
function resetKey(){localStorage.removeItem('lh_apikey');location.reload();}
document.getElementById('keyInput').addEventListener('keydown',e=>{if(e.key==='Enter')saveKey();});

// Check if key already saved
window.addEventListener('load',()=>{
  if(getKey()){document.getElementById('setupScreen').style.display='none';initApp();}
});

let GEMINI_KEY='';
function initApp(){
  GEMINI_KEY=getKey();
const SYSTEM=`Eres Nova, la asistente de recepción con IA de Lenoah, comercializadora empresarial premium.
PERSONALIDAD: Cálida, elegante, hospitalaria. Como recepcionista de hotel boutique 5 estrellas.
Habla natural, máximo 2-3 oraciones. Detectas idioma (ES/EN) automáticamente y respondes en ese idioma.
FLUJO: 1)Saluda y preséntate como Nova de Lenoah 2)Pide el nombre 3)Úsalo naturalmente 4)Pregunta motivo de visita discretamente 5)Entretén amablemente mientras espera.
INFO LENOAH: Comercializadora de soluciones empresariales premium. Servicios: distribución, importación, logística, consultoría. Tijuana, BC.
Si detectas nombre incluye al final: [N:NombreAqui]
Si detectas motivo incluye al final: [M:MotivoAqui]
Estos tags son internos, no se muestran al visitante.`;

const DAYS=['Domingo','Lunes','Martes','Miércoles','Jueves','Viernes','Sábado'];
const QUOTES=['"Bienvenido. Cada visita es una oportunidad."','"Welcome. Excellence is our daily standard."','"En Lenoah, su tiempo es nuestra prioridad."','"Great partnerships begin with a warm welcome."','"La confianza se construye visita a visita."','"Innovation and hospitality, hand in hand."'];

let hist=[],isL=false,isSp=false,isIdle=true,rec=null;
let visName='',lang='es-MX',visits=[],sesStart=null,curV=null;
let carI=0,carT=null,mouth=0,blinkV=1,blinkC=0,blinkN=180;

function todayKey(){const d=new Date();return`v_${d.getFullYear()}_${d.getMonth()}_${d.getDate()}`;}
try{visits=JSON.parse(localStorage.getItem(todayKey())||'[]');}catch(e){visits=[];}

// CURSOR
const cur=document.getElementById('cur'),cur2=document.getElementById('cur2');
let mx=0,my=0,rx=0,ry=0;
document.addEventListener('mousemove',e=>{mx=e.clientX;my=e.clientY;cur.style.left=mx+'px';cur.style.top=my+'px';});
(function ac(){rx+=(mx-rx)*.12;ry+=(my-ry)*.12;cur2.style.left=rx+'px';cur2.style.top=ry+'px';requestAnimationFrame(ac);})();
document.addEventListener('mousedown',()=>{cur2.style.width='18px';cur2.style.height='18px';});
document.addEventListener('mouseup',()=>{cur2.style.width='32px';cur2.style.height='32px';});

// BG PARTICLES
(function(){
  const c=document.getElementById('bgC'),ctx=c.getContext('2d');
  let W,H,pts=[];
  function rsz(){W=c.width=innerWidth;H=c.height=innerHeight;}rsz();window.addEventListener('resize',rsz);
  for(let i=0;i<85;i++)pts.push({x:Math.random()*2000,y:Math.random()*2000,vx:(Math.random()-.5)*.15,vy:(Math.random()-.5)*.15,r:Math.random()*1.2+.3,o:Math.random()*.32+.07});
  function loop(){ctx.clearRect(0,0,W,H);
    pts.forEach(p=>{p.x+=p.vx;p.y+=p.vy;if(p.x<0)p.x=W;if(p.x>W)p.x=0;if(p.y<0)p.y=H;if(p.y>H)p.y=0;
      ctx.beginPath();ctx.arc(p.x%W,p.y%H,p.r,0,Math.PI*2);ctx.fillStyle=`rgba(62,207,142,${p.o})`;ctx.fill();});
    for(let i=0;i<pts.length;i++)for(let j=i+1;j<pts.length;j++){
      const a=pts[i],b=pts[j],dx=a.x-b.x,dy=a.y-b.y,d=Math.sqrt(dx*dx+dy*dy);
      if(d<105){ctx.beginPath();ctx.moveTo(a.x%W,a.y%H);ctx.lineTo(b.x%W,b.y%H);ctx.strokeStyle=`rgba(62,207,142,${.055*(1-d/105)})`;ctx.lineWidth=.5;ctx.stroke();}}
    requestAnimationFrame(loop);}loop();
})();

// FACE
(function(){
  const c=document.getElementById('faceC'),ctx=c.getContext('2d');
  function draw(){const W=90,H=90;ctx.clearRect(0,0,W,H);
    [[28,34],[62,34]].forEach(([ex,ey])=>{ctx.beginPath();ctx.ellipse(ex,ey,5.5,6.5*blinkV,0,0,Math.PI*2);ctx.fillStyle='rgba(62,207,142,.9)';ctx.fill();
      if(blinkV>.5){ctx.beginPath();ctx.arc(ex+2,ey-2,1.5,0,Math.PI*2);ctx.fillStyle='rgba(255,255,255,.5)';ctx.fill();}});
    ctx.beginPath();ctx.moveTo(45,41);ctx.lineTo(41,50);ctx.lineTo(49,50);ctx.strokeStyle='rgba(62,207,142,.18)';ctx.lineWidth=.8;ctx.stroke();
    const my2=62+mouth*7;ctx.beginPath();ctx.moveTo(32,60);ctx.quadraticCurveTo(45,my2,58,60);ctx.strokeStyle='rgba(62,207,142,.85)';ctx.lineWidth=1.8;ctx.lineCap='round';ctx.stroke();
    const g=ctx.createRadialGradient(45,42,0,45,42,35);g.addColorStop(0,'rgba(62,207,142,.05)');g.addColorStop(1,'transparent');ctx.fillStyle=g;ctx.fillRect(0,0,W,H);
    blinkC++;if(blinkC>=blinkN){blinkC=0;blinkN=100+Math.random()*220;}
    if(blinkC<8)blinkV=blinkC<4?1-(blinkC/4):(blinkC-4)/4;else blinkV=1;
    requestAnimationFrame(draw);}draw();
})();

