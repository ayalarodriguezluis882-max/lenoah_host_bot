function playWake(cb){
  const ly=document.getElementById('wkL'),cv=document.getElementById('wkC'),ctx=cv.getContext('2d');
  cv.width=innerWidth;cv.height=innerHeight;ly.classList.add('on');
  const cx=innerWidth/2,cy=innerHeight/2,N=65,pts=[];
  for(let i=0;i<N;i++){const a=Math.random()*Math.PI*2,r=Math.max(innerWidth,innerHeight)*.75;pts.push({x:cx+Math.cos(a)*r,y:cy+Math.sin(a)*r,tx:cx+(Math.random()-.5)*160,ty:cy+(Math.random()-.5)*160,r:Math.random()*2+.8,o:Math.random()*.7+.3});}
  let s=null;function step(ts){if(!s)s=ts;const p=Math.min((ts-s)/1100,1),e=1-Math.pow(1-p,3);
    ctx.clearRect(0,0,cv.width,cv.height);
    if(p>.45){const bp=(p-.45)/.55,g=ctx.createRadialGradient(cx,cy,0,cx,cy,260*bp);g.addColorStop(0,`rgba(62,207,142,${.16*(1-bp)})`);g.addColorStop(1,'transparent');ctx.fillStyle=g;ctx.fillRect(0,0,cv.width,cv.height);}
    pts.forEach(pt=>{ctx.beginPath();ctx.arc(pt.x+(pt.tx-pt.x)*e,pt.y+(pt.ty-pt.y)*e,pt.r,0,Math.PI*2);ctx.fillStyle=`rgba(62,207,142,${pt.o*(1-p*.6)})`;ctx.fill();});
    if(p<1)requestAnimationFrame(step);else{ly.classList.remove('on');ctx.clearRect(0,0,cv.width,cv.height);if(cb)cb();}}
  requestAnimationFrame(step);}

