function vhToggleMic() {
  if (vhListening) {
    vhRec?.stop(); vhListening = false;
    document.getElementById('vhMicBtn').textContent = '🎤 Dictar VIN';
    return;
  }
  const SR = window.SpeechRecognition || window.webkitSpeechRecognition;
  if (!SR) { showToast('Voz no disponible'); return; }
  vhRec = new SR(); vhRec.lang = 'es-MX'; vhRec.continuous = false; vhRec.interimResults = false;
  vhRec.onresult = e => {
    // Clean spoken VIN (remove spaces, hyphens)
    const raw = e.results[0][0].transcript.toUpperCase().replace(/[\s\-]/g,'');
    document.getElementById('vinInput').value = raw;
    vhValidateVin(raw);
  };
  vhRec.onend = () => { vhListening = false; document.getElementById('vhMicBtn').textContent = '🎤 Dictar VIN'; };
  vhRec.start(); vhListening = true;
  document.getElementById('vhMicBtn').textContent = '🔴 Escuchando';
}

