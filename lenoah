      <div style="color:var(--amber);">Honorarios Lenoah (30%)</div>
      <div style="color:var(--amber);font-family:var(--font-m);text-align:right;">${fmt(honorarios)}</div>
    </div>
    <div style="height:1px;background:rgba(240,180,41,.2);margin:8px 0;"></div>
    <div style="display:grid;grid-template-columns:1fr auto;font-size:14px;font-weight:500;">
      <div style="color:var(--text);">TOTAL ESTIMADO</div>
      <div style="color:var(--jade);font-family:var(--font-m);font-size:16px;">${fmt(totalFinal)}</div>
    </div>
  </div>

  <!-- RESTRICCIONES Y NOMs -->
  ${(restrictions.length || noms.length) ? `
  <div style="border:1px solid rgba(248,113,113,.25);padding:10px;margin-bottom:8px;background:rgba(248,113,113,.04);">
    <div style="font-size:8px;letter-spacing:.3em;text-transform:uppercase;color:#f87171;margin-bottom:7px;">⚠ Requisitos regulatorios</div>
    ${restrictions.map(r=>`<div style="font-size:11px;color:var(--text-2);margin-bottom:3px;">• ${r}</div>`).join('')}
    ${noms.map(n=>`<div style="font-size:11px;color:#f0b429;margin-bottom:3px;">📋 ${n}</div>`).join('')}
  </div>` : ''}

  <!-- DISCLAIMER -->
  <div style="padding:8px;border:1px solid var(--border);background:rgba(5,7,10,.4);margin-bottom:4px;">
    <div style="font-size:9px;color:var(--text-3);line-height:1.55;">⚠ Cotización preliminar orientativa. El tipo de cambio usado es referencial (~$20.50). Los impuestos finales dependen de la verificación documental. Un agente aduanal certificado de Lenoah validará la clasificación y el presupuesto definitivo.</div>
  </div>`;

  qzAddDivider('resultado de clasificación');
  const card = qzAddBubble('nova', html, 'result');

  // Store result data
  qzState.result = { data, subtotalImpuestos, honorarios, totalFinal, valAduana, igi, iva, dta, ieps, fmt };
}

// ── PARSER DE RESPUESTA IA ────────────────────────────
function qzParseClassification(text) {
  const match = text.match(/\[CLASIFICACION:(.*?)\]/s);
  if (!match) return null;
  try { return JSON.parse(match[1]); } catch(e) { return null; }
}

// ── ENVIAR PREGUNTA AL CLASIFICADOR ──────────────────
async function qzAsk(userMsg) {
  if (userMsg.trim()) {
    qzAddBubble('user', userMsg);
    qzHistory.push({ role: 'user', parts: [{ text: userMsg }] });
  }
  document.getElementById('qzInput').value = '';
  qzAddThinking();

  try {
    const res = await fetch(
      `https://generativelanguage.googleapis.com/v1beta/models/gemini-2.0-flash:generateContent?key=${GEMINI_KEY}`,
      { method: 'POST', headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          system_instruction: { parts: [{ text: CLASSIFIER_PROMPT }] },
          contents: qzHistory,
          generationConfig: { maxOutputTokens: 600, temperature: 0.3 }
        })
      }
    );
    const d = await res.json();
    let reply = d.candidates?.[0]?.content?.parts?.[0]?.text || 'Error de conexión.';

    // Check if classification is ready
    const classData = qzParseClassification(reply);
    const cleanReply = reply.replace(/\[CLASIFICACION:.*?\]/s, '').trim();

    qzHideThinking();
    qzAddBubble('nova', cleanReply.replace(/\n/g, '<br>'));
    qzHistory.push({ role: 'model', parts: [{ text: reply }] });

    // If we got classification data, extract financials and render card
    if (classData) {
      // Try to extract values from history
      const histText = qzHistory.map(h => h.parts[0].text).join(' ');
      const invoiceMatch = histText.match(/factura[^\d]*(\d[\d,\.]+)/i) || histText.match(/\$\s*(\d[\d,\.]+)/);
      const freightMatch = histText.match(/flete[^\d]*(\d[\d,\.]+)/i);
      const invoice = invoiceMatch ? parseFloat(invoiceMatch[1].replace(/,/g,'')) : qzState.invoiceUSD || 0;
      const freight = freightMatch ? parseFloat(freightMatch[1].replace(/,/g,'')) : qzState.freightUSD || 0;
      const insurance = invoice * 0.015;
      const tlcApplies = qzState.tlc && (qzState.origin.toLowerCase().includes('eeuu') || qzState.origin.toLowerCase().includes('estados unidos') || qzState.origin.toLowerCase().includes('usa'));

      qzRenderResult({
        fraction: classData.fraccion?.substring(0,4) || '',
        fractionFull: classData.fraccion || '',
        desc: classData.descripcion || '',
        invoiceUSD: invoice,
        freightUSD: freight,
        insuranceUSD: insurance,
        igiPct: tlcApplies ? (classData.tlc_igi || 0) : (classData.igi || 10),
        iepsPct: classData.ieps || 0,
        tlc: tlcApplies,
        origin: qzState.origin || 'No especificado',
        product: qzState.product || 'No especificado',
        restrictions: classData.restricciones || [],
        noms: classData.noms || [],
        confidence: classData.confianza || 'MEDIA',
        alternatives: classData.alternativas || []
      });
    }

    // Track state from responses
    if (reply.toLowerCase().includes('país') || reply.toLowerCase().includes('origen')) qzState.step = 'origin';
    if (reply.toLowerCase().includes('valor') || reply.toLowerCase().includes('factura')) qzState.step = 'value';

  } catch(e) {
    qzHideThinking();
    qzAddBubble('nova', 'Error de conexión. Por favor verifica tu internet e intenta de nuevo.');
  }
}

// ── INICIAR WIZARD ────────────────────────────────────
function qzStart() {
  qzState = { step: 'product', product:'', origin:'', tlc:false, invoiceUSD:0, freightUSD:0, insuranceUSD:0 };
  qzHistory = [];
  qzPanel().innerHTML = '';
  qzAddDivider('nueva consulta arancelaria');
  qzAsk('Hola, quiero hacer una consulta de clasificación arancelaria para importar una mercancía a México.');
}

function qzSend() {
  const val = document.getElementById('qzInput').value.trim();
  if (!val) return;

  // Extract data from user input to track state
  const lower = val.toLowerCase();
  if (qzState.step === 'product') { qzState.product = val; qzState.step = 'origin'; }
  if (lower.includes('eeuu') || lower.includes('estados unidos') || lower.includes('usa') || lower.includes('americano')) {
    qzState.origin = 'Estados Unidos (EE.UU.)';
  }
  if (lower.includes('tmec') || lower.includes('t-mec') || lower.includes('certificado de origen') || lower.includes('form a')) {
    qzState.tlc = true;
  }
  const numMatch = val.match(/(\d[\d,\.]+)/);
  if (numMatch) {
    const n = parseFloat(numMatch[1].replace(/,/g,''));
    if (qzState.step === 'value' && !qzState.invoiceUSD) qzState.invoiceUSD = n;
    else if (qzState.step === 'freight' && !qzState.freightUSD) qzState.freightUSD = n;
  }

  qzAsk(val);
}

function qzReset() {
  qzPanel().innerHTML = '';
  qzHistory = [];
  qzState = { step: 'idle', product:'', origin:'', tlc:false, invoiceUSD:0, freightUSD:0, insuranceUSD:0 };
  qzAddDivider('clasificador arancelario · México');
  qzAddBubble('nova', `
    <div style="margin-bottom:10px;font-size:13px;font-family:var(--font-d);font-style:italic;">Bienvenido al Clasificador Arancelario</div>
    <div style="font-size:11px;color:var(--text-2);line-height:1.65;margin-bottom:12px;">
      Puedo ayudarte a:<br>
      <b style="color:var(--text);">① Clasificar</b> tu mercancía en la fracción arancelaria correcta (TIGIE 2022)<br>
      <b style="color:var(--text);">② Calcular</b> IGI, IVA, DTA e IEPS estimados<br>
      <b style="color:var(--text);">③ Detectar</b> restricciones, permisos y NOMs aplicables<br>
      <b style="color:var(--text);">④ Generar</b> cotización preliminar con honorarios Lenoah
    </div>
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:6px;">
      <button onclick="qzStart()" style="padding:8px;border:1px solid var(--jade);background:var(--jade-dim);color:var(--jade);font-family:var(--font-b);font-size:9px;letter-spacing:.2em;text-transform:uppercase;cursor:none;width:100%;">▶ Iniciar consulta</button>
      <button onclick="qzShowSaved()" style="padding:8px;border:1px solid var(--border);background:transparent;color:var(--text-2);font-family:var(--font-b);font-size:9px;letter-spacing:.2em;text-transform:uppercase;cursor:none;width:100%;">📋 Historial</button>
    </div>
  `);
}

function qzSaveQuote() {
  if (!qzState.result) { showToast('Primero completa una clasificación'); return; }
  const q = {
    date: new Date().toLocaleDateString('es-MX'),
    time: nowT(),
    product: qzState.product,
    fraction: qzState.result?.data?.fractionFull || '',
    total: qzState.result?.totalFinal || 0,
    visitor: visName || 'Sin nombre'
  };
  savedQuotes.push(q);
  localStorage.setItem('lh_quotes', JSON.stringify(savedQuotes));
  showToast('Cotización guardada · ' + q.date);
}

function qzShowSaved() {
  qzPanel().innerHTML = '';
  qzAddDivider('historial de cotizaciones');
  if (!savedQuotes.length) {
    qzAddBubble('nova', 'No hay cotizaciones guardadas aún. Inicia una consulta para clasificar una mercancía.');
    return;
  }
  savedQuotes.slice().reverse().forEach(q => {
    qzAddBubble('nova', `
      <div style="font-size:10px;color:var(--text-3);">${q.date} ${q.time} · ${q.visitor}</div>
      <div style="font-size:13px;color:var(--text);margin:3px 0;">${q.product}</div>
      <div style="display:flex;justify-content:space-between;align-items:center;margin-top:6px;">
        <div style="font-family:var(--font-m);font-size:10px;color:var(--jade);">${q.fraction}</div>
        <div style="font-family:var(--font-m);font-size:13px;color:var(--amber);">$${q.total.toLocaleString('es-MX',{maximumFractionDigits:0})}</div>
      </div>
    `);
  });
}

// ── MIC PARA COTIZACIÓN ───────────────────────────────
function qzToggleMic() {
  if (qzListening) {
    qzRec?.stop(); qzListening = false;
    document.getElementById('qzMicBtn').textContent = '🎤 Voz';
    return;
  }
  const SR = window.SpeechRecognition || window.webkitSpeechRecognition;
  if (!SR) { showToast('Voz no disponible'); return; }
  qzRec = new SR(); qzRec.lang = lang; qzRec.continuous = false; qzRec.interimResults = false;
  qzRec.onresult = e => {
    const txt = e.results[0][0].transcript;
    document.getElementById('qzInput').value = txt;
    qzSend();
  };
  qzRec.onend = () => { qzListening = false; document.getElementById('qzMicBtn').textContent = '🎤 Voz'; };
  qzRec.start(); qzListening = true;
  document.getElementById('qzMicBtn').textContent = '🔴 Escuchando';
}

// ── INIT COTIZACIÓN ───────────────────────────────────
function initQuoteModule() {
  qzReset();
}
