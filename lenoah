function showToast(msg,d=2400){const t=document.getElementById('toast');t.textContent=msg;t.classList.add('show');setTimeout(()=>t.classList.remove('show'),d);}

function startCar(){clearInterval(carT);carT=setInterval(()=>{const el=document.getElementById('iQuote');el.style.opacity='0';setTimeout(()=>{carI=(carI+1)%QUOTES.length;el.textContent=QUOTES[carI];el.style.opacity='1';},500);},4500);}

function enterIdle(){isIdle=true;document.getElementById('idle').classList.remove('gone');document.getElementById('app').classList.remove('on');window.speechSynthesis?.cancel();setWave(false);setMouth(false);startCar();document.getElementById('iVis').textContent=visits.length;}
function wakeUp(){if(!isIdle)return;clearInterval(carT);playWake(()=>{isIdle=false;document.getElementById('idle').classList.add('gone');document.getElementById('app').classList.add('on');if(hist.length===0)setTimeout(greet,700);});}
