    const d=await r.json();const tmp=Math.round(d.current.temperature_2m),wc=d.current.weather_code;
    const ico=wc===0?'☀️':wc<=2?'⛅':wc<=3?'☁️':wc<=48?'🌫':wc<=67?'🌧':wc<=82?'🌦':'⛈';
    document.getElementById('iTemp').textContent=tmp+'°';document.getElementById('wxT').textContent=tmp+'°C';document.getElementById('wxIco').textContent=ico;
  }catch(e){document.getElementById('iTemp').textContent='--°';}}
