function vhDecodeVinLocally(vin) {
  if (!vin || vin.length !== 17) return null;
  const wmi = vin[0];
  const countryChar = vin[0];
  let country = 'Desconocido';
  // Map first char to country
  if ('12345'.includes(countryChar)) country = 'EE.UU.';
  else if (countryChar === '2') country = 'Canadá';
  else if (countryChar === '3') country = 'México';
  else if ('JKL'.includes(countryChar)) country = countryChar === 'J' ? 'Japón' : countryChar === 'K' ? 'Corea del Sur' : 'China';
  else if ('VWXYZ'.includes(countryChar)) country = countryChar === 'W' ? 'Alemania' : countryChar === 'V' ? 'Francia' : countryChar === 'Z' ? 'Italia' : 'Europa';
  else if ('ST'.includes(countryChar)) country = 'Reino Unido';
  else if (countryChar === '9') country = 'Brasil/Argentina';
  else if (countryChar === '6') country = 'Australia';

  const yearChar = vin[9];
  // Full VIN year table (cycles every 30 years, 1980 onwards)
  const yearMap = 'ABCDEFGHJKLMNPRSTUVWXYZ123456789';
  const yearBase = [
    1980,1981,1982,1983,1984,1985,1986,1987,1988,1989,
    1990,1991,1992,1993,1994,1995,1996,1997,1998,1999,
    2000,2001,2002,2003,2004,2005,2006,2007,2008,2009,
    2010,2011
  ];
  let modelYear = null;
  const idx = yearMap.indexOf(yearChar);
  if (idx >= 0) {
    modelYear = yearBase[idx];
    // After 2010 the cycle continues: A=2010, B=2011... so if < 2010 and idx < 10 could be +30
    if (modelYear < 2000 && modelYear >= 1980) {
      // Could be 30 years later cycle
      const alternative = modelYear + 30;
      if (alternative <= new Date().getFullYear() + 1) modelYear = alternative;
    }
  }

  const currentYear = new Date().getFullYear();
  const age = modelYear ? currentYear - modelYear : null;
  const isTmec = ['1','2','3','4','5'].includes(countryChar);

  return { vin, country, modelYear, age, isTmec, wmi: vin.substring(0,3), vds: vin.substring(3,9), vis: vin.substring(9) };
}

